# AWS Configuration
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_SESSION_TOKEN=your_session_token
AWS_REGION=us-west-2

# AgentCore Gateway Configuration
AGENTCORE_GATEWAY_ENDPOINT=https://xxx.execute-api.us-west-2.amazonaws.com/prod

# AgentCore Memory Configuration
# AgentCore Memory のリソースID（CDKデプロイ後に取得）
# 長期記憶の有効/無効は Frontend の設定画面でユーザーごとに制御します
AGENTCORE_MEMORY_ID=your-memory-id

# Bedrock Configuration
BEDROCK_MODEL_ID=jp.anthropic.claude-sonnet-4-6
BEDROCK_REGION=ap-northeast-1

# Debug Configuration
LOG_LEVEL=info
DEBUG_MCP=false

# Tavily Search Configuration
# Tavily tools (tavily_search / tavily_extract / tavily_crawl) are now provided
# by the tavily-tools Lambda (AgentCore Gateway Target). The Runtime no longer
# reads TAVILY_API_KEY or TAVILY_API_KEY_SECRET_NAME — those are consumed by
# the Lambda function only, so no agent-side env var is needed.

# Backend API URL (required)
BACKEND_API_URL=http://localhost:3001

# Cognito Identity Pool (required for user-scoped S3/DynamoDB access)
# Run `npm run setup-env` from the project root to auto-populate these values.
IDENTITY_POOL_ID=your-identity-pool-id
COGNITO_USER_POOL_ID=your-user-pool-id

# Cognito App Client IDs (required for aws-jwt-verify allow-list).
# The runtime verifies access tokens against these client IDs and rejects
# tokens minted for any other App Client in the same user pool. The
# machine-user client is only required when Client-Credentials-Flow
# invocations are used for this deployment.
COGNITO_USER_POOL_CLIENT_ID=your-frontend-client-id
# COGNITO_MACHINE_USER_CLIENT_ID=your-machine-user-client-id

# User-scoped credentials (production / deployed environment only)
# These are injected automatically by CDK as container environment variables in the
# AgentCore Runtime. Do NOT set them here for local development — the agent will use
# your local AWS credentials (Admin role) directly, which avoids the sts:TagSession
# permission requirement that is only granted to the AgentCore ExecutionRole.
#
# If you need to test user-scoped S3 access locally, grant sts:TagSession on the
# UserScopedRole trust policy to your local IAM role and set these manually.
#
# USER_SCOPED_ROLE_ARN=arn:aws:iam::123456789012:role/agentcore-user-scoped-role
# SESSIONS_TABLE_ARN=arn:aws:dynamodb:us-west-2:123456789012:table/agentcore-sessions

# S3 User Storage Configuration (optional)
USER_STORAGE_BUCKET_NAME=your-user-storage-bucket-name

# Sessions Table Name (optional, used for DynamoDB queries)
SESSIONS_TABLE_NAME=agentcore-sessions

# AppSync Events Configuration (for real-time message sync)
# ローカル開発時は setup-env で自動設定されます
# APPSYNC_HTTP_ENDPOINT=https://xxx.appsync-api.region.amazonaws.com/event
