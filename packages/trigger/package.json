{
  "name": "@moca/trigger",
  "version": "0.1.0",
  "description": "Event-driven trigger Lambda for AgentCore invocations",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -b",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix && prettier --write \"src/**/*.{ts,tsx,js,jsx}\"",
    "test": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --passWithNoTests --forceExit",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --config jest.integration.config.ts --forceExit",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules --no-warnings' jest --coverage",
    "clean": "rimraf dist"
  },
  "keywords": [
    "agentcore",
    "trigger",
    "scheduler",
    "eventbridge"
  ],
  "author": "AgentCore Trigger",
  "license": "MIT",
  "dependencies": {
    "@moca/core": "*",
    "@aws-sdk/client-dynamodb": "^3.654.0",
    "@aws-sdk/client-ssm": "^3.1017.0",
    "@aws-sdk/util-dynamodb": "^3.654.0",
    "pino": "^10.3.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "dotenv": "^17.2.3",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.6.0"
  },
  "engines": {
    "node": ">=22.12.0"
  }
}
